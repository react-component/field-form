{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@@/*": [
        "./src/.umi/*"
      ],
      "rc-field-form": [
        "./src/index.tsx"
      ]
    },
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "strictFunctionTypes": false,
    "strict": false,
    "noImplicitThis": false,
    "strictBindCallApply": false,
    "module": "ESNext"
  },
  "include": [
    "react-compat.d.ts",
    "global.d.ts",
    ".dumirc.ts",
    ".fatherrc.ts",
    "src",
    "tests",
    "docs"
  ]
}
